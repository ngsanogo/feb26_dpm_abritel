{
  "annotations": {"list": []},
  "description": "Vue exécutive CODIR : KPIs, évolution volume, gravité, top catégories problématiques.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "id": 1,
      "title": "Total avis exploitables",
      "datasource": {"type": "postgres", "uid": "voc-postgres"},
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]},
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "voc-postgres"},
        "format": "table",
        "rawSql": "SELECT COUNT(*) AS \"value\" FROM marts.fact_reviews WHERE is_exploitable = TRUE;"
      }]
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Note moyenne (toutes marques)",
      "datasource": {"type": "postgres", "uid": "voc-postgres"},
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "orange", "value": 2.5},
              {"color": "yellow", "value": 3.5},
              {"color": "green", "value": 4}
            ]
          },
          "unit": "short",
          "decimals": 2,
          "max": 5,
          "min": 0
        },
        "overrides": []
      },
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "voc-postgres"},
        "format": "table",
        "rawSql": "SELECT AVG(rating)::numeric(10,2) AS \"value\" FROM marts.fact_reviews WHERE is_exploitable = TRUE;"
      }]
    },
    {
      "type": "stat",
      "id": 3,
      "title": "% gravité haute",
      "datasource": {"type": "postgres", "uid": "voc-postgres"},
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.2},
              {"color": "orange", "value": 0.35},
              {"color": "red", "value": 0.5}
            ]
          },
          "unit": "percentunit",
          "decimals": 1
        },
        "overrides": []
      },
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "voc-postgres"},
        "format": "table",
        "rawSql": "SELECT SUM(CASE WHEN sev.code='high' THEN 1 ELSE 0 END)::float / NULLIF(COUNT(*),0) AS \"value\" FROM marts.fact_reviews r JOIN marts.fact_classifications fc ON fc.review_id=r.id JOIN marts.dim_severity sev ON sev.id=fc.severity_id WHERE r.is_exploitable = TRUE;"
      }]
    },
    {
      "type": "stat",
      "id": 4,
      "title": "Tickets critiques ouverts",
      "datasource": {"type": "postgres", "uid": "voc-postgres"},
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 20},
              {"color": "orange", "value": 50},
              {"color": "red", "value": 100}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "voc-postgres"},
        "format": "table",
        "rawSql": "SELECT COUNT(*) AS \"value\" FROM marts.fact_tickets;"
      }]
    },
    {
      "type": "stat",
      "id": 5,
      "title": "Gap Abritel vs concurrents (note)",
      "datasource": {"type": "postgres", "uid": "voc-postgres"},
      "gridPos": {"h": 4, "w": 8, "x": 16, "y": 0},
      "description": "Note moyenne Abritel − moyenne (Airbnb, Booking). Négatif = Abritel sous-performe.",
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "orange", "value": -0.5},
              {"color": "yellow", "value": -0.2},
              {"color": "green", "value": 0}
            ]
          },
          "unit": "short",
          "decimals": 2
        },
        "overrides": []
      },
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "voc-postgres"},
        "format": "table",
        "rawSql": "WITH per_brand AS (SELECT b.code AS brand_code, AVG(r.rating)::float AS avg_rating FROM marts.fact_reviews r JOIN marts.dim_brand b ON b.id=r.brand_id WHERE r.is_exploitable=TRUE GROUP BY b.code) SELECT (MAX(CASE WHEN brand_code='abritel' THEN avg_rating END) - AVG(CASE WHEN brand_code IN ('airbnb','booking') THEN avg_rating END))::numeric(10,2) AS \"value\" FROM per_brand;"
      }]
    },
    {
      "type": "timeseries",
      "id": 6,
      "title": "Volume d'avis par jour, par marque",
      "datasource": {"type": "postgres", "uid": "voc-postgres"},
      "gridPos": {"h": 9, "w": 16, "x": 0, "y": 4},
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "fillOpacity": 70,
            "stacking": {"mode": "normal", "group": "A"},
            "axisPlacement": "auto"
          },
          "color": {"mode": "palette-classic"},
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "voc-postgres"},
        "format": "time_series",
        "rawSql": "SELECT date_trunc('day', r.review_date)::timestamptz AS time, b.label AS metric, COUNT(*) AS value FROM marts.fact_reviews r JOIN marts.dim_brand b ON b.id=r.brand_id WHERE r.is_exploitable=TRUE AND $__timeFilter(r.review_date) GROUP BY 1, 2 ORDER BY 1;"
      }]
    },
    {
      "type": "piechart",
      "id": 7,
      "title": "Distribution gravité",
      "datasource": {"type": "postgres", "uid": "voc-postgres"},
      "gridPos": {"h": 9, "w": 8, "x": 16, "y": 4},
      "options": {
        "legend": {"displayMode": "list", "placement": "right", "showLegend": true, "values": ["value", "percent"]},
        "pieType": "donut",
        "displayLabels": ["percent"]
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "mappings": [],
          "unit": "short"
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "high"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]},
          {"matcher": {"id": "byName", "options": "medium"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "orange"}}]},
          {"matcher": {"id": "byName", "options": "low"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]}
        ]
      },
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "voc-postgres"},
        "format": "table",
        "rawSql": "SELECT sev.code AS metric, COUNT(*) AS value FROM marts.fact_reviews r JOIN marts.fact_classifications fc ON fc.review_id=r.id JOIN marts.dim_severity sev ON sev.id=fc.severity_id WHERE r.is_exploitable=TRUE GROUP BY sev.code ORDER BY CASE sev.code WHEN 'high' THEN 1 WHEN 'medium' THEN 2 ELSE 3 END;"
      }]
    },
    {
      "type": "barchart",
      "id": 8,
      "title": "Top catégories (volume + % gravité haute)",
      "description": "Bar = volume d'avis exploitables ; couleur = % avis gravité haute (rouge si critique).",
      "datasource": {"type": "postgres", "uid": "voc-postgres"},
      "gridPos": {"h": 10, "w": 12, "x": 0, "y": 13},
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "showValue": "auto",
        "stacking": "none",
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": false},
        "tooltip": {"mode": "single", "sort": "none"}
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-RdYlGr",
            "fixedColor": "blue"
          },
          "custom": {"lineWidth": 1, "fillOpacity": 80, "axisPlacement": "auto"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "voc-postgres"},
        "format": "table",
        "rawSql": "SELECT c.label AS category, COUNT(*) AS volume, ROUND(100.0 * SUM(CASE WHEN sev.code='high' THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 1) AS pct_high FROM marts.fact_reviews r JOIN marts.fact_classifications fc ON fc.review_id=r.id JOIN marts.dim_category c ON c.id=fc.category_id JOIN marts.dim_severity sev ON sev.id=fc.severity_id WHERE r.is_exploitable=TRUE GROUP BY c.label ORDER BY volume DESC;"
      }]
    },
    {
      "type": "table",
      "id": 9,
      "title": "Avis critiques récents (top 15)",
      "description": "Avis exploitables, gravité 'high', triés du plus récent au plus ancien.",
      "datasource": {"type": "postgres", "uid": "voc-postgres"},
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 13},
      "options": {
        "showHeader": true,
        "footer": {"show": false}
      },
      "fieldConfig": {
        "defaults": {
          "custom": {"align": "auto", "displayMode": "auto", "filterable": true},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}]}
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "rating"}, "properties": [{"id": "custom.width", "value": 60}, {"id": "custom.cellOptions", "value": {"type": "color-background"}}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "orange", "value": 2}, {"color": "yellow", "value": 3}, {"color": "green", "value": 4}]}}]},
          {"matcher": {"id": "byName", "options": "extrait"}, "properties": [{"id": "custom.width", "value": 380}]}
        ]
      },
      "targets": [{
        "refId": "A",
        "datasource": {"type": "postgres", "uid": "voc-postgres"},
        "format": "table",
        "rawSql": "SELECT r.review_date AS date, b.label AS marque, src.label AS source, c.label AS catégorie, r.rating, SUBSTR(r.text, 1, 200) AS extrait FROM marts.fact_reviews r JOIN marts.fact_classifications fc ON fc.review_id=r.id JOIN marts.dim_severity sev ON sev.id=fc.severity_id JOIN marts.dim_brand b ON b.id=r.brand_id JOIN marts.dim_source src ON src.id=r.source_id JOIN marts.dim_category c ON c.id=fc.category_id WHERE r.is_exploitable=TRUE AND sev.code='high' ORDER BY r.review_date DESC LIMIT 15;"
      }]
    }
  ],
  "refresh": "5m",
  "schemaVersion": 39,
  "tags": ["voc", "executive"],
  "templating": {"list": []},
  "time": {"from": "now-90d", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "VoC — Executive Overview",
  "uid": "voc-executive",
  "version": 1,
  "weekStart": ""
}
