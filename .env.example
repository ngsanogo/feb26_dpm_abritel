# Copier en .env si tu veux surcharger les défauts.
# Sur Linux, AIRFLOW_UID = $(id -u) — sur Mac/Windows, laisser 50000.
AIRFLOW_UID=50000

# Fenêtre de scraping (jours) — augmente si tu veux plus d'avis pour la démo.
VOC_SCRAPE_WINDOW_DAYS=30

# Plafonds par source (limite la durée du scraping).
VOC_GP_MAX_PAGES=3
VOC_AS_MAX_PAGES=3
VOC_TP_MAX_PAGES=2
# Cap dur sur le nb d'avis collectés par (source × marque). 0 = pas de cap.
VOC_MAX_REVIEWS_PER_SOURCE=100

# --- Airflow login (UI http://localhost:8080) ---
AIRFLOW_ADMIN_USER=airflow
AIRFLOW_ADMIN_PASSWORD=airflow
# Clé Flask partagée entre scheduler et webserver (évite le 403 sur fetch de logs).
# Valeur factice pour la démo locale uniquement — remplacer en tout environnement exposé.
AIRFLOW_SECRET_KEY=CHANGE_ME_AIRFLOW_SECRET_KEY

# --- Postgres exposé localement (port hôte 5433) ---
# Connectable depuis l'hôte : psql -h localhost -p 5433 -U postgres -d voc
# Bases hébergées :
#   - `airflow`  : metadata Airflow
#   - `voc`      : data warehouse VoC (schéma `marts` lu par Superset)
#   - `superset` : metadata Superset
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=airflow
VOC_PG_DBNAME=voc

# --- Superset (UI http://localhost:8088) ---
# Login UI Superset (créé automatiquement par superset-init au premier démarrage).
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_ADMIN_EMAIL=admin@voc.local
SUPERSET_ADMIN_FIRSTNAME=Admin
SUPERSET_ADMIN_LASTNAME=User
# Clé secrète pour signer les sessions Flask. **À changer en prod**.
# Génération : `python -c "import secrets; print(secrets.token_urlsafe(42))"`
SUPERSET_SECRET_KEY=CHANGE_ME_SUPERSET_SECRET_KEY

# --- Ollama (catégorisation LLM des avis non_classe) ---
# Ollama tournant sur le Mac hôte (depuis Docker) :
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Ollama tournant dans Docker (profile with-ollama) — décommenter et commenter la ligne ci-dessus :
# OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT_SECONDS=60
# Désactive complètement l'étape LLM si vide ou false.
OLLAMA_ENABLED=true

# --- Notion (ticketing — laisser vide pour désactiver, fallback CSV uniquement) ---
NOTION_TOKEN=
NOTION_DATABASE_ID=

# --- Slack (notifications — laisser vide pour désactiver) ---
SLACK_WEBHOOK_URL=
